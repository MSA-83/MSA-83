# Titanium Environment Configuration

# App Configuration
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30
JWT_REFRESH_EXPIRATION_DAYS=7

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Embedding Provider (ollama, groq, huggingface)
EMBEDDER_PROVIDER=ollama
GROQ_API_KEY=
HUGGINGFACE_API_KEY=

# Vector Store (memory, qdrant, chroma)
VECTOR_STORE=memory
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# Database (SQLite for dev, Neon Postgres for prod)
DATABASE_URL=sqlite:///./titanium.db
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/titanium

# Redis (optional, falls back to in-memory)
REDIS_URL=redis://localhost:6379/0

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_PUBLISHABLE_KEY=pk_test_

# Email Configuration (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Sentry (optional)
SENTRY_DSN=

# Prometheus
PROMETHEUS_ENABLED=true

# Feature Flag Overrides (FLAG_<name>=value)
# FLAG_ENABLE_BILLING=false
