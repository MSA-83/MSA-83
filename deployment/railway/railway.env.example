# Railway Environment Variables
# Copy these to your Railway project's Variables tab

# Required - Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/titanium?sslmode=require

# Required - JWT
JWT_SECRET_KEY=your-256-bit-secret-key-here-change-in-production

# Optional - Redis (Upstash)
REDIS_URL=redis://default:password@xxx.upstash.io:6379
REDIS_TOKEN=your-upstash-token

# Optional - Vector DB (Qdrant Cloud)
QDRANT_URL=https://xxx-xxx.us-east.aws.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# Optional - LLM Providers
OLLAMA_BASE_URL=http://localhost:11434
LLM_PROVIDER=ollama
GROQ_API_KEY=gsk_your-groq-api-key-here
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional - OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Optional - Frontend URL (for OAuth callbacks)
FRONTEND_URL=https://your-app.railway.app

# Internal - Railway sets these automatically
# PORT - automatically set by Railway
# RAILWAY_ENVIRONMENT - automatically set by Railway
